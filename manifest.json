{
  "manifest_version": 3,
  "name": "YT Rec Fix — YouTube Recommendation Fix",
  "version": "0.2.0",
  "description": "One-click watched/not-interested + local rec hiding. Hide YouTube sections: Shorts, For You, Feature, Explore topics, Most relevant. Fast feedback without the 5-step menu.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content/yt-rec-fix.js"],
      "css": ["content/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png"
    }
  },
  "permissions": ["storage", "activeTab", "tabs"],
  "optional_host_permissions": ["https://www.youtube.com/*"],
  "browser_specific_settings": {
    "gecko": {
      "id": "yt-rec-fix@danney.ytaddon",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}
