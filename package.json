{
  "name": "yt-rec-fix",
  "version": "0.2.1",
  "description": "Firefox addon: one-click rec blocking, local hiding, and optional YouTube section hiding",
  "private": true,
  "scripts": {
    "dev": "web-ext run --target=firefox-desktop --source-dir . --verbose",
    "dev:win": "web-ext run --target=firefox-desktop --source-dir . --verbose --firefox-binary=\"C:\\\\Program Files\\\\Mozilla Firefox\\\\firefox.exe\"",
    "dev:chromium": "web-ext run -t chromium --source-dir .",
    "build": "npm run build:firefox && npm run build:chrome",
    "build:firefox": "node scripts/build-firefox.mjs",
    "build:chrome": "node scripts/build-chrome.mjs",
    "lint": "web-ext lint --source-dir ."
  },
  "devDependencies": {
    "web-ext": "^10.3.0"
  }
}
