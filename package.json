{
  "name": "yt-rec-fix",
  "version": "0.1.0",
  "description": "Firefox addon: one-click watched + not-interested + local hiding for YouTube recommendations",
  "private": true,
  "scripts": {
    "dev": "web-ext run --firefox-desktop --source-dir . --verbose",
    "dev:chromium": "web-ext run -t chromium --source-dir .",
    "build": "web-ext build --overwrite-dest --source-dir . --artifacts-dir dist",
    "lint": "web-ext lint --source-dir ."
  },
  "devDependencies": {
    "web-ext": "^8.2.0"
  }
}
